default_platform(:android)

platform :android do
  desc "Build Android release AAB"
  lane :build_release do
    gradle(
      task: "bundle",
      build_type: "Release",
      project_dir: "."
    )
  end

  desc "Upload Android to internal track"
  lane :deploy_internal do
    gradle(
      task: "bundle",
      build_type: "Release",
    )

    upload_to_play_store(
      json_key: "fastlane_tmp/android_service_account.json",
      track: "internal",
      aab: "./composeApp/build/outputs/bundle/release/composeApp-release.aab",
      package_name: "com.dh.ondot",
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true
    )
  end

  desc "Upload Android to production track"
  lane :deploy_production do
    gradle(
      task: "bundle",
      build_type: "Release",
    )

    upload_to_play_store(
      json_key: "fastlane_tmp/android_service_account.json",
      track: "production",
      aab: "./composeApp/build/outputs/bundle/release/composeApp-release.aab",
      package_name: "com.dh.ondot",
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true
    )
  end
end

platform :ios do
  desc "Build iOS release"
  lane :deploy_testflight do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_PRIVATE_KEY"],
      is_key_content_base64: true
    )

    create_keychain(
      name: "fastlane_tmp_keychain",
      password: ENV["MATCH_KEYCHAIN_PASSWORD"],
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false
    )

    import_certificate(
      certificate_path: "./fastlane_tmp/ondot_distribution.p12",
      certificate_password: ENV["IOS_DISTRIBUTION_P12_PASSWORD"],
      keychain_name: "fastlane_tmp_keychain",
      keychain_password: ENV["MATCH_KEYCHAIN_PASSWORD"]
    )

    install_provisioning_profile(
      path: "./fastlane_tmp/OnDot_AppStore.mobileprovision"
    )

    install_provisioning_profile(
      path: "./fastlane_tmp/OnDotAlarmWidget_AppStore.mobileprovision"
    )

    build_app(
      project: "iosApp/iosApp.xcodeproj",
      scheme: "iosApp",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.dh.ondot.iosApp" => "match AppStore com.dh.ondot.iosApp",
          "com.dh.ondot.iosApp.OnDotAlarmWidget" => "match AppStore com.dh.ondot.iosApp.OnDotAlarmWidget"
        }
      }
    )

    upload_to_testflight(
      api_key: api_key
    )
  end

  desc "Build iOS release locally without upload"
  lane :build_release_local do
    create_keychain(
      name: "fastlane_tmp_keychain",
      password: ENV["MATCH_KEYCHAIN_PASSWORD"],
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false
    )

    import_certificate(
      certificate_path: "./fastlane_tmp/ondot_distribution.p12",
      certificate_password: ENV["IOS_DISTRIBUTION_P12_PASSWORD"],
      keychain_name: "fastlane_tmp_keychain",
      keychain_password: ENV["MATCH_KEYCHAIN_PASSWORD"]
    )

    install_provisioning_profile(
      path: "./fastlane_tmp/OnDot_AppStore.mobileprovision"
    )

    install_provisioning_profile(
      path: "./fastlane_tmp/OnDotAlarmWidget_AppStore.mobileprovision"
    )

    build_app(
      project: "iosApp/iosApp.xcodeproj",
      scheme: "iosApp",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.dh.ondot.iosApp" => "match AppStore com.dh.ondot.iosApp",
          "com.dh.ondot.iosApp.OnDotAlarmWidget" => "match AppStore com.dh.ondot.iosApp.OnDotAlarmWidget"
        }
      }
    )
  end
end
